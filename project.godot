; Engine configuration file.
; Trade Empire Rush — Godot 4.x project (MVP).
;
; El overnight construye el juego desde este esqueleto. Las primeras
; rondas deben:
;   1. Descargar Godot 4 portable a D:\empire-rush\godot\godot.exe
;      (si no está ya).
;   2. Abrir este project.godot con ese Godot para regenerar .godot/.
;   3. Construir Main.tscn + scripts del loop base.

config_version=5

[application]

config/name="Trade Empire Rush"
config/description="Empieza con nada. Construye un imperio. Idle tycoon / management runner isométrico. MVP web (HTML5) primero, luego Android e iOS."
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://assets/sprites/icon.svg"

[autoload]

GameManager="*res://scripts/autoload/game_manager.gd"
Economy="*res://scripts/autoload/economy.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[input]

move_up={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":87,"physical_keycode":0,"key_label":0,"unicode":119,"location":0,"echo":false,"script":null)
]
}
